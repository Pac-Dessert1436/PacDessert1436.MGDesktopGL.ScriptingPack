<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>PacDessert1436.MGDesktopGL.ScriptingPack</id>
    <version>1.0.0</version>
    <title>MonoGame DesktopGL Scripting Pack</title>
    <authors>Pac-Dessert1436</authors>
    <owners>Pac-Dessert1436</owners>
    <license type="expression">BSD-3-Clause</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <readme>README.md</readme>
    <description>A feature-rich set of MonoGame DesktopGL 2D game templates, with JScript and 
      VBScript scripting support using Microsoft ClearScript.</description>
    <tags>monogame;game-scripting;jscript;vbscript;template;dotnet</tags>
    <packageTypes>
      <packageType name="Template" />
    </packageTypes>
    <repository type="git"
      url="https://github.com/Pac-Dessert1436/PacDessert1436.MGDesktopGL.ScriptingPack" />
  </metadata>
  <files>
    <file src="MonoGameJScript/**/*"
      exclude="**/bin/**/*;**/obj/**/*;**/.git/**/*;**/*.user;**/*.suo;**/*.vsidx;**/*.dtbcache.v2;**/*.slnx;**/*.nupkg;**/*.nuspec;**/.vs/**/*;**/project.assets.json;**/*.AssemblyInfo.vb;**/.NETCoreApp*;**/Content/bin/**/*"
      target="content" />
    <file src="MonoGameVBScript/**/*"
      exclude="**/bin/**/*;**/obj/**/*;**/.git/**/*;**/*.user;**/*.suo;**/*.vsidx;**/*.dtbcache.v2;**/*.slnx;**/*.nupkg;**/*.nuspec;**/.vs/**/*;**/project.assets.json;**/*.AssemblyInfo.vb;**/.NETCoreApp*;**/Content/bin/**/*"
      target="content" />
    <file src="README.md" target="README.md" />
  </files>
</package>